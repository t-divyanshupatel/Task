/docs
/docs-util
/www
typedoc.*
jest*

packages/*
# List of packages to Lint
!packages/medusa
!packages/admin-ui
!packages/admin
!packages/admin-next
!packages/admin-next/dashboard
!packages/medusa-payment-stripe
!packages/medusa-payment-paypal
!packages/modules/event-bus-redis
!packages/modules/event-bus-local
!packages/medusa-plugin-meilisearch
!packages/medusa-plugin-algolia
!packages/modules/inventory
!packages/modules/stock-location
!packages/modules/cache-redis
!packages/modules/cache-inmemory
!packages/modules/caching
!packages/modules/providers/caching-redis
!packages/create-medusa-app
!packages/modules/product
!packages/modules/locking
!packages/modules/translation
!packages/core/orchestration
!packages/core/workflows-sdk
!packages/core/core-flows
!packages/core/types
!packages/medusa-react
!packages/modules/workflow-engine-redis
!packages/modules/workflow-engine-inmemory
!packages/modules/fulfillment
!packages/modules/providers/fulfillment-manual
!packages/modules/providers/locking-postgres
!packages/modules/providers/locking-redis
!packages/modules/index
!packages/eslint-plugin

# Linted by @medusajs/eslint-plugin (Medusa convention rules). The root config
# scopes the google/prettier/type style rules away from these via STYLE_EXCLUDED.
!packages/plugins
!packages/modules
# Re-allow core-flows and framework under packages/core. Grandchild negations
# can't re-include while the parent dir is excluded (packages/* excludes the
# packages/core directory), so re-include the parent, re-exclude its children,
# then re-include the specific packages we lint.
# Note: framework is linted only for the style/other rules — the Medusa rules
# are turned off for it in .eslintrc.js (see MEDUSA_EXCLUDED_DIRS).
!packages/core
packages/core/*
!packages/core/core-flows
!packages/core/framework


**/models/*
**/scripts/*
**/dist/*
**/node_modules/*
**/migrations/*
**/__mocks__/*

# Re-allow module data models so the Medusa data-model rules can lint them
# (the style rules still skip them via STYLE_EXCLUDED).
!packages/modules/**/models/**

.eslintrc.js
